{
    "name": "plank/publisher",
    "description": "A workflow for publishing content in Laravel applications.",
    "keywords": [
        "Plank",
        "laravel",
        "publisher"
    ],
    "homepage": "https://github.com/plank/publisher",
    "license": "MIT",
    "authors": [
        {
            "name": "Kurt Friars",
            "email": "kfriars@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13",
        "plank/before-and-after-model-events": "^13.0",
        "plank/laravel-hush": "^13.1",
        "plank/laravel-model-resolver": "^13",
        "plank/laravel-pivot-events": "^13.0",
        "plank/laravel-schema-events": "^13",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^11.0.0",
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Plank\\Publisher\\": "src/",
            "Plank\\Publisher\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Plank\\Publisher\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Plank\\Publisher\\PublisherServiceProvider"
            ],
            "aliases": {
                "Publisher": "Plank\\Publisher\\Facades\\Publisher"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
